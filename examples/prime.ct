// Citius Example: Prime Numbers
func is_prime(n) {
    if n < 2 {
        return 0
    }
    i = 2
    while i * i <= n {
        if n % i == 0 {
            return 0
        }
        i = i + 1
    }
    return 1
}

func main() {
    count = 0
    n = 2
    while n <= 100 {
        if is_prime(n) {
            printi(n)
            print("\n")
            count = count + 1
        }
        n = n + 1
    }
    print("count = ")
    print(count)
}
